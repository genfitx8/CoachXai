# ─── PayApp ───────────────────────────────────────────────────────────────────
# Server-side secret key (NEVER expose to client)
PAYAPP_SECRET_KEY=

# (Optional) Base URL for PayApp confirm API
PAYAPP_API_BASE=https://api.payapp.kr/v1/payments

# (Optional) Hosted checkout URL. If not set, local dev uses mock redirect.
PAYAPP_CHECKOUT_URL=

# ─── App ──────────────────────────────────────────────────────────────────────
# Base URL for redirect after payment (no trailing slash)
APP_BASE_URL=http://localhost:3000

# API base URL used by Vite client to reach the backend
VITE_API_BASE_URL=http://localhost:4000

# ─── Firebase Admin (optional – leave empty for local-only dev) ───────────────
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# ─── Backend server port (default: 4000) ─────────────────────────────────────
PORT=4000

# ─── Gemini / Other existing keys ────────────────────────────────────────────
GEMINI_API_KEY=
API_KEY=

# ─── KakaoTalk Share ──────────────────────────────────────────────────────────
# JavaScript App Key from Kakao Developers console (https://developers.kakao.com)
# Required to enable the "카카오톡으로 공유하기" button in the lesson detail view.
# Register your site's domain under [My Application] → [Platform] → [Web].
VITE_KAKAO_APP_KEY=
