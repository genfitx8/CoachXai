# ─── Cloudflare R2 (File Storage) ────────────────────────────────────────────
# Required for lesson video/image uploads. Create an R2 bucket and API token
# at https://dash.cloudflare.com → R2 → Manage R2 API Tokens.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Name of the R2 bucket (defaults to "coachxai" if not set)
R2_BUCKET=coachxai

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# Render provides this automatically via the linked database
# For local dev: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=

# ─── PayApp ───────────────────────────────────────────────────────────────────
# Server-side secret key (NEVER expose to client)
PAYAPP_SECRET_KEY=

# (Optional) Base URL for PayApp confirm API
PAYAPP_API_BASE=https://api.payapp.kr/v1/payments

# (Optional) Hosted checkout URL. If not set, local dev uses mock redirect.
PAYAPP_CHECKOUT_URL=

# ─── App ──────────────────────────────────────────────────────────────────────
# Base URL for redirect after payment (no trailing slash)
APP_BASE_URL=http://localhost:3000
# Allowed CORS origins for API access (comma-separated, use * only in development)
APP_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# API base URL used by Vite client to reach the backend
VITE_API_BASE_URL=http://localhost:4000

# ─── Firebase (Google Login / Signup) ─────────────────────────────────────────
# Required for Google authentication in the client.
# Copy values from Firebase Project Settings > General > Your apps (Web app config).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
# Optional but recommended when using Firebase services beyond auth.
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# ─── Backend server port (default: 4000) ─────────────────────────────────────
PORT=4000

# ─── SMTP Mail (Password Recovery) ────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="CoachXai <no-reply@coachxai.local>"

# ─── Gemini AI Studio (Direct REST, simplest option) ──────────────────────────
# Obtain a key from https://aistudio.google.com/app/apikey
# When set this takes highest priority over Agent Platform / Agent Runtime.
GEMINI_API_KEY=
# Optional: override the default model (default: gemini-2.0-flash)
GEMINI_MODEL=

# ─── Google Cloud Agent Platform Runtime (server-side) ──────────────────────
# This app calls an already-deployed agent runtime from the backend.
# Do not expose AI keys in Vite/browser variables.
#
# Option A – Agent Platform Runtime (preferred)
# Set AGENT_PLATFORM_AGENT_RESOURCE to the full agent resource path, e.g.
#   projects/<project-id>/locations/<location>/reasoningEngines/<agent-id>
# The backend will derive the endpoint automatically from AGENT_PLATFORM_LOCATION.
AGENT_PLATFORM_LOCATION=us-central1
AGENT_PLATFORM_AGENT_RESOURCE=
# Optional: override the full endpoint URL (takes precedence over the derived URL)
AGENT_PLATFORM_RUNTIME_ENDPOINT=
# Optional: supply a static Bearer token for local testing instead of ADC
AGENT_PLATFORM_ACCESS_TOKEN=

# Option B – Legacy Agent Runtime (used when Option A vars are not set)
GCP_PROJECT_ID=
GCP_LOCATION=
# Full deployed agent resource name, e.g.
# projects/<project-id>/locations/<location>/reasoningEngines/<agent-id>
# (Resource segment can vary by runtime deployment type; use the exact name from GCP.)
GCP_AGENT_RESOURCE_NAME=
# Optional override. Defaults to https://<location>-aiplatform.googleapis.com/v1
GCP_AGENT_PLATFORM_API_BASE_URL=

# ─── KakaoTalk Share ──────────────────────────────────────────────────────────
# JavaScript App Key from Kakao Developers console (https://developers.kakao.com)
# Required to enable the "카카오톡으로 공유하기" button in the lesson detail view.
# Register your site's domain under [My Application] → [Platform] → [Web].
VITE_KAKAO_APP_KEY=
