# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# Render provides this automatically via the linked database
# For local dev: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=

# ─── PayApp ───────────────────────────────────────────────────────────────────
# Server-side secret key (NEVER expose to client)
PAYAPP_SECRET_KEY=

# (Optional) Base URL for PayApp confirm API
PAYAPP_API_BASE=https://api.payapp.kr/v1/payments

# (Optional) Hosted checkout URL. If not set, local dev uses mock redirect.
PAYAPP_CHECKOUT_URL=

# ─── App ──────────────────────────────────────────────────────────────────────
# Base URL for redirect after payment (no trailing slash)
APP_BASE_URL=http://localhost:3000
# Allowed CORS origins for API access (comma-separated, use * only in development)
APP_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# API base URL used by Vite client to reach the backend
VITE_API_BASE_URL=http://localhost:4000

# ─── Firebase (Google Login / Signup) ─────────────────────────────────────────
# Required for Google authentication in the client.
# Copy values from Firebase Project Settings > General > Your apps (Web app config).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
# Optional but recommended when using Firebase services beyond auth.
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# ─── Backend server port (default: 4000) ─────────────────────────────────────
PORT=4000

# ─── SMTP Mail (Password Recovery) ────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="CoachXai <no-reply@coachxai.local>"

# ─── Google Cloud Agent Platform Runtime (Server-side only) ─────────────────
# Use one of:
# 1) AGENT_PLATFORM_RUNTIME_ENDPOINT (full invoke URL), or
# 2) AGENT_PLATFORM_AGENT_RESOURCE with AGENT_PLATFORM_LOCATION
#    e.g. projects/{PROJECT}/locations/{LOCATION}/reasoningEngines/{AGENT_ID}
AGENT_PLATFORM_RUNTIME_ENDPOINT=
AGENT_PLATFORM_AGENT_RESOURCE=
AGENT_PLATFORM_LOCATION=us-central1

# Optional aliases for tooling compatibility
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=

# Preferred auth: Application Default Credentials (GOOGLE_APPLICATION_CREDENTIALS).
# Optional fallback for local testing only (short-lived OAuth token):
AGENT_PLATFORM_ACCESS_TOKEN=

# ─── KakaoTalk Share ──────────────────────────────────────────────────────────
# JavaScript App Key from Kakao Developers console (https://developers.kakao.com)
# Required to enable the "카카오톡으로 공유하기" button in the lesson detail view.
# Register your site's domain under [My Application] → [Platform] → [Web].
VITE_KAKAO_APP_KEY=
