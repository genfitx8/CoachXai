# ─── Server runtime ──────────────────────────────────────────────────────────
# Express listens on this port. Render injects PORT automatically, so leave
# this commented in production.
# PORT=4000

# ─── CORS / public URLs ──────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call this API. Include both the
# Render static-site URL and any custom domains. Use "*" only for development.
APP_ALLOWED_ORIGINS=https://coachxai-web.onrender.com,https://www.coachxai.com

# Fallback when APP_ALLOWED_ORIGINS is empty. Also used by payment routes to
# build success/fail redirect URLs.
APP_BASE_URL=https://coachxai-web.onrender.com

# ─── PayApp (https://payapp.kr) ──────────────────────────────────────────────
# Required for /api/payments/payapp* routes. Treat as secrets.
PAYAPP_SECRET_KEY=
# Optional overrides — leave blank to use the documented defaults.
PAYAPP_API_BASE=https://api.payapp.kr/v1/payments
PAYAPP_CHECKOUT_URL=

# ─── Toss Payments (https://docs.tosspayments.com) ───────────────────────────
# Required only if the Toss route is re-enabled in src/index.ts. Treat as a
# secret.
TOSS_SECRET_KEY=

# ─── Firebase Admin (optional persistence) ───────────────────────────────────
# When both are set the server stores payment orders + point credits in
# Firestore instead of the local server/data/*.json file. The latter does not
# survive container restarts on Render's free tier — set these in production.
FIREBASE_PROJECT_ID=
# Path to a service-account key JSON file mounted into the container. On
# Render, upload the key as a Secret File and point this var at /etc/secrets/<filename>.
GOOGLE_APPLICATION_CREDENTIALS=

# ─── Postgres (provisioned by render.yaml) ───────────────────────────────────
# Render injects DATABASE_URL automatically when the service is linked to a
# Postgres instance. The current server code does not consume it yet — kept
# here so future migrations can switch over without touching infra config.
# DATABASE_URL=
